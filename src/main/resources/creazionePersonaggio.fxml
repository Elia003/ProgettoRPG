<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg123022.Controller.CreazionePersonaggioController"
            prefHeight="620.0"
            prefWidth="960.0"
            style="-fx-background-color: linear-gradient(to bottom, #f7f1e3, #e8dcc8);">

    <center>
        <VBox alignment="CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>

            <children>
                <Label text="Creazione Personaggio"
                       style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #8b4513;"/>

                <GridPane alignment="CENTER" hgap="18.0" vgap="18.0" maxWidth="520.0">
                    <children>
                        <Label text="Nome:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="nomeField"
                                   promptText="Inserisci il nome"
                                   prefWidth="260.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="0"/>

                        <Label text="Colore capelli:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="coloreCapelliField"
                                   promptText="Inserisci il colore"
                                   prefWidth="260.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1"/>

                        <Label text="Classe:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <ChoiceBox fx:id="classeChoiceBox"
                                   prefWidth="260.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="2"/>

                        <Label text="Genere:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <ChoiceBox fx:id="genereChoiceBox"
                                   prefWidth="260.0"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="3"/>
                    </children>
                </GridPane>

                <HBox alignment="CENTER" spacing="18.0">
                    <children>
                        <Button text="Crea"
                                onAction="#createPersonaggio"
                                prefWidth="140.0"
                                prefHeight="42.0"
                                style="-fx-background-color: #8d3b2f; -fx-text-fill: white;"/>
                        <Button text="indietro"
                                onAction="#exit"
                                prefWidth="140.0"
                                prefHeight="42.0"
                                style="-fx-background-color: #5e5e5e; -fx-text-fill: white;"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>
