    <bottom>
<VBox alignment="CENTER">
    <padding>
        <Insets bottom="10.0" />
    </padding>
        <Button onAction="#exit" prefHeight="22.0" prefWidth="80.0" style="-fx-background-color: #5e5e5e; -fx-text-fill: white;-fx-background-radius: 300.0;" text="indietro">
