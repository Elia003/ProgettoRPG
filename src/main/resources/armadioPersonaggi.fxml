                </padding>
                <Button onAction="#impostaPersonaggio2Attivo" text="Imposta come attivo" prefWidth="175"/>
            </VBox>
        </children>
        <children>
            <VBox alignment="CENTER_RIGHT">

             <Button onAction="#impostaPersonaggio3Attivo" text="Imposta come attivo" prefWidth="175"/>
