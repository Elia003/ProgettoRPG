<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg123022.Controller.InventarioPersonaggioController"
            prefHeight="620.0"
            prefWidth="960.0"
            style="-fx-background-color: linear-gradient(to bottom, rgba(76, 33, 17, 1), rgba(115, 32, 3, 1));">
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER" alignment="CENTER">
        <padding>
            <Insets top="40.0" right="18.0"  left="18.0"/>
        </padding>
        <Label fx:id="titoloLabel"
               text="Inventario Personaggi"
               style=" -fx-font-size: 40px;
        -fx-text-fill: rgba(158, 158, 158, 1) "/>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER">

            <VBox spacing="15"
                  prefWidth="500"
                  style="-fx-background-color: rgba(198, 179, 170, 1);
                         -fx-background-radius: 14;
                         -fx-padding: 20;">

                <Label text="Oggetti Equipaggiati"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-text-fill: black;
                              -fx-background-color: rgba(198, 179, 170, 1) "/>

                <ListView fx:id="listaOggettiPersonaggio"
                          prefHeight="350"
                          prefWidth="400"/>

            </VBox>

        </VBox>

    </center>
<bottom>
    <VBox alignment="CENTER">
        <padding>
            <Insets bottom="10.0"/>
        </padding>
        <Button text="indietro"
                onAction="#exit"
                prefWidth="80.0"
                prefHeight="22.0"
                style="-fx-background-color: #5e5e5e; -fx-text-fill: white;-fx-background-radius: 300.0;">
        </Button>
    </VBox>
</bottom>
</BorderPane>
