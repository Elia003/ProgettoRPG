<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.unicam.cs.mpgc.rpg123022.Controller.CombattimentoController"
            prefHeight="620.0"
            prefWidth="960.0"
            style="-fx-background-color: linear-gradient(to bottom, #f7f1e3, #e8dcc8);">
    <top>
        <VBox spacing="8.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="18.0" bottom="8.0" left="18.0"/>
            </padding>
            <children>
                <Label fx:id="titoloLabel"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2f241f;"
                       text="Combattimento"/>
                <HBox spacing="24.0">
                    <children>
                        <Label fx:id="roundLabel"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;"
                               text="Round: 0"/>
                        <Label fx:id="turnoLabel"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;"
                               text="Turno: -"/>
                        <Label fx:id="statoLabel"
                               style="-fx-font-size: 14px; -fx-font-weight: bold;"
                               text="Stato: in corso"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <VBox spacing="14.0">
            <padding>
                <Insets top="8.0" right="18.0" bottom="18.0" left="18.0"/>
            </padding>
            <children>
                <HBox spacing="18.0">
                    <children>
                        <VBox spacing="10.0"
                              prefWidth="420.0"
                              style="-fx-background-color: rgba(255,255,255,0.75); -fx-background-radius: 14; -fx-padding: 18;">
                            <children>
                                <Label text="Giocatore 1"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6a3d1d;"/>
                                <Label fx:id="giocatore1NomeLabel"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold;"
                                       text="Nome"/>
                                <Label fx:id="giocatore1ClasseLabel" text="Classe: -"/>
                                <Label fx:id="giocatore1AttaccoLabel" text="Attacco: -"/>
                                <Label fx:id="giocatore1DifesaLabel" text="Difesa: -"/>
                                <Label fx:id="giocatore1RisorsaLabel" text="Risorsa: -"/>
                                <Label fx:id="giocatore1HpLabel" text="HP: -"/>
                                <ProgressBar fx:id="giocatore1HpBar" prefWidth="9999.0" progress="1.0"/>
                            </children>
                        </VBox>
                        <VBox spacing="10.0"
                              prefWidth="420.0"
                              style="-fx-background-color: rgba(255,255,255,0.75); -fx-background-radius: 14; -fx-padding: 18;">
                            <children>
                                <Label text="Giocatore 2"
                                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1d4d6a;"/>
                                <Label fx:id="giocatore2NomeLabel"
                                       style="-fx-font-size: 20px; -fx-font-weight: bold;"
                                       text="Nome"/>
                                <Label fx:id="giocatore2ClasseLabel" text="Classe: -"/>
                                <Label fx:id="giocatore2AttaccoLabel" text="Attacco: -"/>
                                <Label fx:id="giocatore2DifesaLabel" text="Difesa: -"/>
                                <Label fx:id="giocatore2RisorsaLabel" text="Risorsa: -"/>
                                <Label fx:id="giocatore2HpLabel" text="HP: -"/>
                                <ProgressBar fx:id="giocatore2HpBar" prefWidth="9999.0" progress="1.0"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="12.0">
                    <children>
                        <Button fx:id="attaccaButton"
                                mnemonicParsing="false"
                                onAction="#onAttacca"
                                prefWidth="140.0"
                                style="-fx-background-color: #8d3b2f; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Attacca"/>
                        <Button fx:id="resetButton"
                                mnemonicParsing="false"
                                onAction="#onReset"
                                prefWidth="140.0"
                                style="-fx-background-color: #596275; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Reset"/>
                        <Button mnemonicParsing="false"
                                onAction="#onCaricaDemo"
                                prefWidth="140.0"
                                style="-fx-background-color: #567d46; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Demo"/>
                    </children>
                </HBox>
                <Separator/>
                <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="Registro del combattimento"
                               style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <TextArea fx:id="logArea"
                                  editable="false"
                                  prefRowCount="14"
                                  style="-fx-font-family: 'Consolas'; -fx-font-size: 13px;"
                                  wrapText="true"
                                  VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox alignment="CENTER">
            <padding>
                <Insets bottom="10.0"/>
            </padding>
            <Button text="indietro"
                    onAction="#exit"
                    prefWidth="80.0"
                    prefHeight="22.0"
                    style="-fx-background-color: #5e5e5e; -fx-text-fill: white;-fx-background-radius: 300.0;">
            </Button>
        </VBox>
    </bottom>
</BorderPane>
